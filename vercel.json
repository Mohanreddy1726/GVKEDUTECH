{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "www.gvkedutech.com"
        }
      ],
      "destination": "https://gvkedutech.com/:path",
      "permanent": true,
      "statusCode": 301
    }
  ]
}